<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	style="@style/TTheme.Numpad.Column.Fn"
	android:id="@+id/numpad_column_fn_left">

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_1">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeySettings
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_settings" />
		<include layout="@layout/key_overlay_side_chars" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_2">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyAddWord
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_add_word"
			tools:ignore="Instantiatable" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_3">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyShift
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_shift" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_4">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyLF4
			style="@style/TTheme.Numpad.Key.LF4"
			android:id="@+id/soft_key_lf4" />
		<include layout="@layout/key_overlay_lf4" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_L">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyArrow
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_left_arrow"
			android:text="@string/key_dpad_left"/>
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_R">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyArrow
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_right_arrow"
			android:text="@string/key_dpad_right"/>
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_C">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyShowTextEditing
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_text_editing" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_V">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyVoiceInput
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_voice_input" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_E">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyShowEmojis
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_show_emojis" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_T">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyTogglePredictiveMode
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_toggle_predictive_mode" />
	</RelativeLayout>

	<RelativeLayout style="@style/TTheme.Numpad.Key.Overlay.Wrapper" android:id="@+id/soft_key_wrapper_N">
		<io.github.sspanak.tt9.ui.main.keys.SoftKeyNextLanguage
			style="@style/TTheme.Numpad.Key.Large"
			android:id="@+id/soft_key_extra_next_language" />
		<include layout="@layout/key_overlay_icons" />
	</RelativeLayout>
</LinearLayout>
